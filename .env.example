# YahooClaw Environment Variables
# Copy this file to .env and fill in your values

# ===========================================
# API Keys (Optional - for higher rate limits)
# ===========================================

# Yahoo Finance API (Optional)
# Get from: https://finance.yahoo.com/
YAHOO_API_KEY=your_yahoo_api_key_here

# Alpha Vantage API (Optional - backup data source)
# Get from: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here

# ===========================================
# Database Configuration
# ===========================================

# SQLite database path (default: ./clawmem.db)
DATABASE_PATH=./clawmem.db

# Enable WAL mode for better performance (true/false)
DATABASE_WAL_MODE=true

# ===========================================
# API Configuration
# ===========================================

# Request timeout in milliseconds (default: 10000)
API_TIMEOUT=10000

# Enable caching (true/false)
API_CACHE_ENABLED=true

# Cache TTL in milliseconds (default: 300000 = 5 minutes)
API_CACHE_TTL=300000

# ===========================================
# Logging Configuration
# ===========================================

# Log level: error, warn, info, debug (default: info)
LOG_LEVEL=info

# Log file path (default: ./logs/yahooclaw.log)
LOG_FILE=./logs/yahooclaw.log

# ===========================================
# Rate Limiting
# ===========================================

# Max requests per minute (default: 60)
RATE_LIMIT_MAX_REQUESTS=60

# Rate limit window in milliseconds (default: 60000)
RATE_LIMIT_WINDOW_MS=60000
